
<!DOCTYPE html>
<html lang="pt-br">
<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Cadastrar Animal</title>

<link rel="stylesheet" href="style.css">

</head>

<body>

<div class="form-container">

<h1>
🐾 Cadastrar Animal
</h1>

<input
type="text"
id="nome"
placeholder="Nome">

<select id="raca">

<option>Labrador</option>
<option>Poodle</option>
<option>Golden Retriever</option>
<option>Vira-lata</option>
<option>Persa</option>

</select>

<input
type="text"
id="idade"
placeholder="Idade">

<input
type="text"
id="imagem"
placeholder="URL da imagem">

<textarea
id="descricao"
placeholder="Descrição"></textarea>

<button onclick="cadastrarAnimal()">

Cadastrar Animal

</button>

</div>

<script src="script.js"></script>

</body>
</html>
