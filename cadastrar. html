
<!DOCTYPE html>
<html lang="pt-br">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Criar Conta</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{

height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#4facfe,#00c6fb);

}

.box{

background:white;
padding:40px;
border-radius:20px;
width:350px;

}

.box h1{

text-align:center;
margin-bottom:30px;
color:#0d6efd;

}

.box input{

width:100%;
padding:15px;
margin-bottom:20px;
border:1px solid #ddd;
border-radius:10px;

}

.box button{

width:100%;
padding:15px;
border:none;
border-radius:10px;
background:#0d6efd;
color:white;
font-size:18px;

}

.box a{

display:block;
text-align:center;
margin-top:20px;
text-decoration:none;
color:#0d6efd;

}

</style>

</head>

<body>

<div class="box">

<h1>
🐾 Criar Conta
</h1>

<input
type="email"
id="novoEmail"
placeholder="Digite seu email">

<input
type="password"
id="novaSenha"
placeholder="Digite sua senha">

<button onclick="cadastrar()">

Cadastrar

</button>

<a href="index.html">

Voltar para login

</a>

</div>

<script>

let usuarios =
JSON.parse(
localStorage.getItem("usuarios")
)
||
[];

function cadastrar(){

const email =
document.getElementById("novoEmail").value;

const senha =
document.getElementById("novaSenha").value;

usuarios.push({
email,
senha
});

localStorage.setItem(
"usuarios",
JSON.stringify(usuarios)
);

alert(
"✅ Conta criada!"
);

window.location.href =
"index.html";

}

</script>

</body>
</html>
